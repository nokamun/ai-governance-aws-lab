{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowDriftlockDevFullAccess",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::YOUR_ACCOUNT_ID:user/driftlock-dev"
            },
            "Action": "s3:*",
            "Resource": [
                "arn:aws:s3:::driftlock-ai-knowledge-lab-east1",
                "arn:aws:s3:::driftlock-ai-knowledge-lab-east1/*"
            ]
        },
        {
            "Sid": "AllowBedrockServiceRole",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::YOUR_ACCOUNT_ID:role/service-role/AmazonBedrockExecutionRole-driftlock-v2"
            },
            "Action": [
                "s3:GetObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::driftlock-ai-knowledge-lab-east1",
                "arn:aws:s3:::driftlock-ai-knowledge-lab-east1/*"
            ]
        },
        {
            "Sid": "AllowLambdaExecutionRoles",
            "Effect": "Allow",
            "Principal": {
                "AWS": [
                    "arn:aws:iam::YOUR_ACCOUNT_ID:role/AIResearchAssistantLambdaRole",
                    "arn:aws:iam::YOUR_ACCOUNT_ID:role/driftlock-bedrock-assistant-role",
                    "arn:aws:iam::YOUR_ACCOUNT_ID:role/driftlock-guardrail-assistant-role",
                    "arn:aws:iam::YOUR_ACCOUNT_ID:role/driftlock-pii-scanner-role"
                ]
            },
            "Action": [
                "s3:GetObject",
                "s3:ListBucket"
            ],
            "Resource": [
                "arn:aws:s3:::driftlock-ai-knowledge-lab-east1",
                "arn:aws:s3:::driftlock-ai-knowledge-lab-east1/*"
            ]
        },
        {
            "Sid": "DenyUnauthorizedWrites",
            "Effect": "Deny",
            "Principal": "*",
            "Action": [
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:DeleteObjectVersion"
            ],
            "Resource": "arn:aws:s3:::driftlock-ai-knowledge-lab-east1/*",
            "Condition": {
                "StringNotEquals": {
                    "aws:PrincipalArn": "arn:aws:iam::YOUR_ACCOUNT_ID:user/driftlock-dev"
                }
            }
        }
    ]
}
