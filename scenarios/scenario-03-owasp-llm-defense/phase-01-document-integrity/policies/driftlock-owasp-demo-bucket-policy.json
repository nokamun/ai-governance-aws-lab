{
    "Version": "2012-10-17",
    "Statement": [
        {
            "Sid": "AllowDriftlockDevFullAccess",
            "Effect": "Allow",
            "Principal": {
                "AWS": "arn:aws:iam::YOUR_ACCOUNT_ID:user/driftlock-dev"
            },
            "Action": "s3:*",
            "Resource": [
                "arn:aws:s3:::driftlock-owasp-demo",
                "arn:aws:s3:::driftlock-owasp-demo/*"
            ]
        },
        {
            "Sid": "DenyUnauthorizedWrites",
            "Effect": "Deny",
            "Principal": "*",
            "Action": [
                "s3:PutObject",
                "s3:DeleteObject",
                "s3:DeleteObjectVersion"
            ],
            "Resource": "arn:aws:s3:::driftlock-owasp-demo/*",
            "Condition": {
                "StringNotEquals": {
                    "aws:PrincipalArn": "arn:aws:iam::YOUR_ACCOUNT_ID:user/driftlock-dev"
                }
            }
        }
    ]
}
